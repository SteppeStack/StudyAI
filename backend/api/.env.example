APP_ENV=development
API_CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# External AI provider. Local AI is intentionally not used for deployability.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_CHAIN=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.5-flash

SUPABASE_STORAGE_BUCKET=study-files
MAX_UPLOAD_SIZE_BYTES=26214400
MAX_ANALYSIS_FILE_SIZE_BYTES=10485760
MAX_AI_INPUT_CHARS=30000
AI_TUTOR_HISTORY_LIMIT=8

# Future billing integration. Server-side only.
PAYMENT_PROVIDER=stripe
PAYMENT_SUCCESS_URL=http://localhost:3000/subscription?success=1
PAYMENT_CANCEL_URL=http://localhost:3000/subscription?canceled=1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STUDENT_PREMIUM_PRICE_ID=
STRIPE_TEACHER_PRICE_ID=
